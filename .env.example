# MoreAI Proxy Configuration

# Internal Chat Configuration
INTERNAL_CHAT_URL=https://chat.qwen.ai/
AUTH_STORAGE_STATE_PATH=

# Shared Google Auth Bootstrap
GOOGLE_AUTH_CREDENTIALS_PATH=./secrets/browser_auth.json
GOOGLE_AUTH_AUTO_BOOTSTRAP=true
GOOGLE_AUTH_TIMEOUT_SECONDS=180
GOOGLE_AUTH_POST_LOGIN_WAIT_SECONDS=10

# Browser Configuration
HEADLESS=true
BROWSER_POOL_SIZE=5
RESPONSE_TIMEOUT_SECONDS=120
RETRY_ATTEMPTS=1
BROWSER_SLOWMO=0

# API / G4F Integrations
INTEGRATIONS_ENABLED=true
INTEGRATIONS_AUTO_DISCOVER_MODELS=true
INTEGRATIONS_DISCOVERY_TIMEOUT_SECONDS=10
INTEGRATIONS_RETRY_ATTEMPTS=1
INTEGRATIONS_ALLOW_FALLBACK_MODELS=true
INTEGRATIONS_CONFIG_PATH=./config/integrations.toml
INTEGRATIONS_RATE_LIMIT_COOLDOWN_SECONDS=60
G4F_API_KEY=

# Debug & Artifacts
ARTIFACTS_DIR=./artifacts
LOG_LEVEL=INFO

# Application
APP_HOST=0.0.0.0
APP_PORT=8000

# Provider-Specific Storage State
QWEN_STORAGE_STATE_PATH=
GLM_STORAGE_STATE_PATH=
CHATGPT_STORAGE_STATE_PATH=
YANDEX_STORAGE_STATE_PATH=

# Kimi
KIMI_URL=https://www.kimi.com/
KIMI_SKIP_AUTH_URL=https://www.kimi.com/?skip_auth=1
KIMI_STORAGE_STATE_PATH=./secrets/kimi.storage_state.json

# DeepSeek
DEEPSEEK_URL=https://chat.deepseek.com/sign_in
DEEPSEEK_LOGIN=
DEEPSEEK_PASSWORD=
