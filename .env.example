# MoreAI Proxy Configuration

# Internal Chat Configuration
INTERNAL_CHAT_URL=https://chat.qwen.ai/
AUTH_STORAGE_STATE_PATH=

# Shared Google Auth Bootstrap
GOOGLE_AUTH_CREDENTIALS_PATH=./secrets/browser_auth.json
GOOGLE_AUTH_AUTO_BOOTSTRAP=true
GOOGLE_AUTH_TIMEOUT_SECONDS=180
GOOGLE_AUTH_POST_LOGIN_WAIT_SECONDS=10

# Browser Configuration
HEADLESS=true
BROWSER_POOL_SIZE=5
RESPONSE_TIMEOUT_SECONDS=120
RETRY_ATTEMPTS=1
BROWSER_SLOWMO=0

# API / G4F Integrations
INTEGRATIONS_ENABLED=true
INTEGRATIONS_AUTO_DISCOVER_MODELS=true
INTEGRATIONS_DISCOVERY_TIMEOUT_SECONDS=10
INTEGRATIONS_RETRY_ATTEMPTS=1
INTEGRATIONS_ALLOW_FALLBACK_MODELS=true
INTEGRATIONS_CONFIG_PATH=./config/integrations.toml
INTEGRATIONS_RATE_LIMIT_COOLDOWN_SECONDS=60
G4F_API_KEY=

# Debug & Artifacts
ARTIFACTS_DIR=./artifacts
LOG_LEVEL=INFO

# Application
APP_HOST=0.0.0.0
APP_PORT=8000

# Provider-Specific Storage State
QWEN_STORAGE_STATE_PATH=
GLM_STORAGE_STATE_PATH=
CHATGPT_STORAGE_STATE_PATH=
YANDEX_STORAGE_STATE_PATH=

# Kimi
KIMI_URL=https://www.kimi.com/
KIMI_SKIP_AUTH_URL=https://www.kimi.com/?skip_auth=1
KIMI_STORAGE_STATE_PATH=./secrets/kimi.storage_state.json

# DeepSeek
DEEPSEEK_URL=https://chat.deepseek.com/sign_in
DEEPSEEK_LOGIN=
DEEPSEEK_PASSWORD=

# OpenCode Agent Server
OPENCODE_ENABLED=true

# Managed lifecycle (default: MoreAI manages the subprocess)
OPENCODE_MANAGED=true
OPENCODE_AUTOSTART=true
OPENCODE_COMMAND=opencode
OPENCODE_PORT=4096
OPENCODE_STARTUP_TIMEOUT_SECONDS=30
OPENCODE_HEALTHCHECK_INTERVAL_SECONDS=1
OPENCODE_GRACEFUL_SHUTDOWN_SECONDS=10
OPENCODE_WORKING_DIR=

# Connection
OPENCODE_BASE_URL=http://127.0.0.1:4096
OPENCODE_USERNAME=opencode
OPENCODE_PASSWORD=
OPENCODE_TIMEOUT_SECONDS=120

# Discovery
OPENCODE_DISCOVERY_ENABLED=true
OPENCODE_SESSION_TTL_SECONDS=60

# Set to true to fail app startup if OpenCode can't start
OPENCODE_REQUIRED=false
OPENCODE_DISCOVERY_REFRESH_INTERVAL_SECONDS=60000

# Kilocode Agent Provider
KILOCODE_ENABLED=true
KILOCODE_BASE_URL=http://127.0.0.1:5096
KILOCODE_USERNAME=kilocode
KILOCODE_PASSWORD=
KILOCODE_TIMEOUT_SECONDS=120
KILOCODE_DISCOVERY_ENABLED=true
KILOCODE_SESSION_TTL_SECONDS=60
KILOCODE_MANAGED=true
KILOCODE_AUTOSTART=true
KILOCODE_COMMAND=kilocode
KILOCODE_PORT=5096
KILOCODE_STARTUP_TIMEOUT_SECONDS=30
KILOCODE_HEALTHCHECK_INTERVAL_SECONDS=1
KILOCODE_GRACEFUL_SHUTDOWN_SECONDS=10
KILOCODE_WORKING_DIR=
KILOCODE_REQUIRED=false
KILOCODE_DISCOVERY_REFRESH_INTERVAL_SECONDS=600

# Admin API
ADMIN_TOKEN=

# Pipeline Orchestration (Chain-of-Providers)
PIPELINE_ENABLED=true
PIPELINE_MAX_STAGES=3
PIPELINE_MAX_TOTAL_TIME_MS=180000
PIPELINE_MAX_STAGE_RETRIES=1

# OpenRouter API Provider
# API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Set to false to disable the OpenRouter provider
OPENROUTER_ENABLED=true
# Only include free models (models with :free suffix)
OPENROUTER_ONLY_FREE=false
# Include the special openrouter/free auto-router model
OPENROUTER_INCLUDE_FREE_ROUTER=false
# Discover models from OpenRouter API at startup
OPENROUTER_DISCOVERY_ON_STARTUP=true
